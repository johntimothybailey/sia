{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 3,
      "description": "The unique name of the skill."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic versioning string (e.g., 1.0.0)."
    },
    "author": {
      "type": "string",
      "description": "The author of the skill."
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1,
      "description": "List of tags for categorizing the skill."
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "A concise summary of the skill's purpose and trigger conditions."
    }
  },
  "required": ["name", "version", "author", "tags", "description"]
}
