{
  "name": "sia-monorepo",
  "private": true,
  "packageManager": "bun@1.2.19",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test:promptfoo": "bun run --filter @sia/promptfoo eval",
    "test:deepeval": "bun run --filter @sia/deepeval test",
    "changeset": "changeset",
    "changeset:release": "changeset version && changeset publish"
  },
  "devDependencies": {
    "turbo": "latest",
    "@changesets/cli": "latest"
  }
}
