{
  "name": "sia-monorepo",
  "private": true,
  "packageManager": "bun@1.2.19",
  "workspaces": [
    "packages/*",
    "skills/*"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo run test",
    "lint:skills": "remark --ext md --rc-path .remarkrc.js skills/",
    "test:promptfoo": "turbo test --filter=@sia/promptfoo",
    "test:promptfoo:ci": "turbo test --filter=@sia/promptfoo -- --no-cache",
    "test:deepeval": "turbo test --filter=@sia/deepeval",
    "changeset": "changeset",
    "changeset:release": "changeset version && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "latest",
    "remark-cli": "^12.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-lint": "^10.0.1",
    "remark-lint-frontmatter-schema": "^3.15.4",
    "turbo": "latest"
  }
}
