# Standard .gitignore for Node.js / Bun / Next.js / Turborepo

# Dependencies
node_modules/
.pnp
.pnp.js
.bun
bun.lockb
# Note: we are keeping bun.lock for bun 1.2+

# Next.js
.next/
out/

# Turborepo
.turbo/

# Build outputs
dist/
build/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo

# OS specific files
.DS_Store
Thumbs.db

# Changesets
.changeset/pre.json
